# Environment Configuration Template
# Copy this file to .env.local and fill in your values

# API Configuration
VITE_API_URL=http://localhost:3001

# Default Model Configuration
# These values are used as defaults when starting a new chat
VITE_DEFAULT_MODEL_PLATFORM=GEMINI
VITE_DEFAULT_MODEL_TYPE=GEMINI_3_FLASH

# Default Model API URL (optional)
# Set this if you're using a custom model endpoint or proxy
# Examples:
#   - Local: http://localhost:11434
VITE_DEFAULT_MODEL_API_URL=

# Available model platforms: GEMINI, OPENAICOMPATIBLE
# Available model types depend on the platform selected
