# =============================================================================
# MedGemma Backend Environment Configuration
# =============================================================================
# These values serve as defaults when the frontend does not provide them.

# --- Model Configuration ---
# Default model platform. Common values:
#   gemini            - Google Gemini API
#   openai            - OpenAI API
#   openai-compatible-model - vLLM / LMStudio / any OpenAI-compat server
MODEL_PLATFORM=gemini

# Default model type/name
#   For Gemini:  gemini-2.0-flash, gemini-1.5-pro, etc.
#   For OpenAI:  gpt-4o, gpt-4o-mini, etc.
#   For vLLM:    medgemma-4b-it
MODEL_TYPE=gemini-3-flash-preview

# API key for the model provider
#   For Gemini: your Google AI Studio API key
#   For OpenAI: your OpenAI API key
GEMINI_API_KEY=AI..

# (Optional) Custom API endpoint URL
#   Required for openai-compatible-model (e.g., http://localhost:8000/v1)
#   Leave empty for cloud providers (Gemini, OpenAI) which use their default URLs
API_URL=

# --- Search Configuration (Optional) ---
# GOOGLE_API_KEY=
# SEARCH_ENGINE_ID=
