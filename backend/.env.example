# =============================================================================
# MedGemma Backend Environment Configuration
# =============================================================================
# These values serve as defaults when the frontend does not provide them.

# --- Model Configuration ---
# Default model platform. Common values:
#   gemini            - Google Gemini API
#   openai            - OpenAI API
#   openai-compatible-model - vLLM / LMStudio / any OpenAI-compat server
MODEL_PLATFORM=gemini

# Default model type/name
#   For Gemini:  gemini-2.0-flash, gemini-1.5-pro, etc.
#   For OpenAI:  gpt-4o, gpt-4o-mini, etc.
#   For vLLM:    medgemma-4b-it
MODEL_TYPE=gemini-3-flash-preview

# API key for the model provider
#   For Gemini: your Google AI Studio API key
#   For OpenAI: your OpenAI API key
GEMINI_API_KEY=AI..

# (Optional) Custom API endpoint URL
#   Required for openai-compatible-model (e.g., http://localhost:8000/v1)
#   Leave empty for cloud providers (Gemini, OpenAI) which use their default URLs
API_URL=

# --- Secondary Agent (MedGemma) Configuration ---
# Used for secondary agent with simulated tool calling
MEDGEMMA_API_URL=https://med.awelkaircodes.org/v1
MEDGEMMA_MODEL_PLATFORM=OPENAI-COMPATIBLE-MODEL
MEDGEMMA_MODEL_TYPE=medgemma-4b

# (Optional) Maximum context window size in tokens for MedGemma agents.
# When set, CAMEL will auto-summarize conversation history when usage
# approaches this limit, preventing "exceed_context_size_error" errors.
# Set this to match your model server's n_ctx value (e.g. 16384, 32768).
# Leave empty to use the model backend's default.
MEDGEMMA_CONTEXT_SIZE=16384

# --- Encryption Key ---
# Used to encrypt/decrypt sensitive data like API keys from frontend
# Generate a key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# --- Search Configuration (Optional) ---
# GOOGLE_API_KEY=
# SEARCH_ENGINE_ID=
