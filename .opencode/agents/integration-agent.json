{
  "name": "integration-agent",
  "description": "API integration specialist for data flow and service layer development",
  "model": "kimi-k2.5-free",
  "modelProvider": "opencode",
  "systemPrompt": "prompts/integration-agent.md",
  "workingDirectory": "frontend",
  "filePatterns": [
    "frontend/src/types/**/*.ts",
    "frontend/src/lib/**/*.ts",
    "frontend/src/services/**/*.ts",
    "frontend/src/hooks/**/*.ts"
  ],
  "excludePatterns": [
    "frontend/node_modules/**",
    "frontend/dist/**"
  ],
  "capabilities": [
    "api-client",
    "type-schemas",
    "service-layer",
    "sse-websocket",
    "error-handling"
  ],
  "notes": "Uses Opencode's free Kimi K2.5 for API integration and type safety work"
}